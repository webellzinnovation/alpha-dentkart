# Server Configuration
PORT=3001
NODE_ENV=development
CLIENT_URL=http://localhost:3000

# Database
DATABASE_URL="file:./dev.db"

# JWT Authentication
JWT_SECRET=replace_with_a_random_string_min_32_characters
JWT_EXPIRES_IN=7d
ADMIN_SECRET=replace_with_admin_registration_secret

# Razorpay
RAZORPAY_KEY_ID=replace_with_razorpay_key_id
RAZORPAY_KEY_SECRET=replace_with_razorpay_key_secret
VITE_RAZORPAY_KEY_ID=replace_with_public_razorpay_key_id

# WordPress Migration (Legacy)
WP_CONSUMER_KEY=replace_with_wordpress_consumer_key
WP_CONSUMER_SECRET=replace_with_wordpress_consumer_secret
