// This is your Prisma schema file
// Learn more: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User model with authentication
model User {
  id                 String  @id @default(uuid())
  email              String  @unique
  password           String // Hashed with bcrypt
  name               String
  phone              String?
  avatar             String?
  role               String  @default("user") // user, admin, dental-doctor
  userType           String  @default("regular") // regular, dental-doctor, student, supplier
  isVerified         Boolean @default(false)
  verificationStatus String  @default("pending") // pending, approved, rejected

  // Dental doctor specific fields
  licenseId       String?
  licenseState    String?
  specialization  String?
  clinicName      String?
  clinicAddress   String?
  yearsOfPractice Int?

  // Student specific fields
  studentId       String?
  institution     String?
  course          String?
  yearOfStudy     Int?
  expectedGraduation String?

  // Supplier specific fields
  gstNumber       String?
  businessName     String?
  businessType     String?
  panNumber       String?
  registrationDate_user  String? // Renamed to avoid conflict
  annualTurnover   String?

  registrationDate DateTime @default(now())
  fcmToken         String? // For push notifications
  
  // WhatsApp integration
  whatsappOptIn    Boolean @default(false)
  whatsappPhone    String?
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  // Relations
  orders              Order[]
  addresses           Address[]
  reviews             Review[]
  returnRequests      ReturnRequest[]
  stockAlerts         StockAlert[]
  verificationDocuments VerificationDocument[]
  verificationAudits  VerificationAudit[]
  whatsappNotifications WhatsAppNotification[]
  savedPaymentMethods SavedPaymentMethod[]
  quickReorders QuickReorder[]
}

// Stock Alert model for low inventory notifications
model StockAlert {
  id            String    @id @default(uuid())
  productId     Int
  userId        String?   // User who created the alert
  threshold     Int
  alertType    String    // low-stock, out-of-stock, high-demand
  isActive     Boolean   @default(true)
  notificationSent Boolean @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  product       Product @relation(fields: [productId], references: [id])
  user          User?   @relation(fields: [userId], references: [id])
}

// Supplier model for dental suppliers
model Supplier {
  id            String    @id @default(uuid())
  name          String
  email         String?
  phone         String?
  address       String?
  contactPerson  String?
  paymentTerms   String?
  leadTime      Int?     // Days for restocking
  isActive      Boolean   @default(true)
  gstNumber     String?   // GST registration
  isoCertified  Boolean   @default(false)
  products_supplied String?   // JSON array of product IDs supplied
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  
  // Relations
  products       Product[]
}

// Product model
model Product {
  id   Int    @id @default(autoincrement())
  name String

  // Relations
  categoryId Int?
  category   Category? @relation(fields: [categoryId], references: [id])
  brandId         Int?
  brand           Brand?    @relation(fields: [brandId], references: [id])
  supplierId     String?
  supplier       Supplier?   @relation(fields: [supplierId], references: [id])
  
  // Legacy fields for migration support (optional, can be phased out)
  categoryName    String?   @map("category") // Mapping old field
  brandName       String?   @map("brand")    // Mapping old field
  
  // Supplier relation

  price            Float
  originalPrice    Float?
  rating           Float?   @default(4.5)
  reviews          Int?     @default(0)
  avgRating        Float?   @default(0)
  reviewCount      Int      @default(0)
  clinicalRating   Float? // Dental professional clinical rating
  customerRating   Float? // Regular customer rating
  image            String?
  images           String? // JSON array of images
  description      String?
  shortDescription String?
  features         String? // JSON array
  specs            String? // JSON object
  attributes       String? // JSON array of attributes
  variations       String? // JSON array of variations
  stock            Int      @default(100)
  badge            String?
  badgeColor       String?
  timer            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  productReviews   Review[]
  stockAlerts      StockAlert[]

  @@index([name])
  @@index([categoryId])
  @@index([brandId])
}

// Order model
model Order {
  id               String            @id @default(uuid())
  userId           String?           // Optional for guest orders
  user             User?             @relation(fields: [userId], references: [id])

  customerName     String
  status           String            @default("Processing") // Processing, Shipped, Delivered, Cancelled
  total            Float
  items            String // JSON array of order items
  shippingAddress  String? // JSON object
  paymentId        String?
  paymentStatus    String?           @default("pending") // pending, paid, failed
  paymentMethod    String? // razorpay, phonepe, cod
  transactionId    String?
  isNew            Boolean           @default(true)
  
  // Guest checkout fields
  guestEmail       String?
  guestPhone       String?
  isGuestOrder     Boolean           @default(false)
  guestSessionId   String?
  
  // Coupon fields
  couponId         String?
  couponDiscount   Float             @default(0)
  
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  ReturnRequest    ReturnRequest[]
  Review           Review[]
  ShippingTracking ShippingTracking?
  UsedCoupon       UsedCoupon?
  guestSession     GuestSession?     @relation(fields: [guestSessionId], references: [sessionId])
  whatsappNotifications WhatsAppNotification[]
  quickReordersAsOriginal QuickReorder[] @relation("QuickReorderOriginalOrder")
  quickReordersAsNew     QuickReorder[] @relation("QuickReorderNewOrder")
}

// Address model
model Address {
  id        Int      @id @default(autoincrement())
  userId    String
  user      User     @relation(fields: [userId], references: [id])

  type      String // Home, Office, Clinic
  name      String
  street    String
  city      String
  state     String
  zip       String
  phone     String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Category model
model Category {
  id        Int       @id @default(autoincrement())
  name      String    @unique
  slug      String    @unique
  iconClass String?
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// Brand model
model Brand {
  id            Int       @id @default(autoincrement())
  name          String    @unique
  slug          String    @unique
  logo          String?
  description   String?
  productCount  Int       @default(0)
  isFeatured    Boolean   @default(false)
  featuredOrder Int?
  products      Product[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

// Return Request model for return management
model ReturnRequest {
  id           String    @id @default(uuid())
  orderId      String
  userId       String
  orderItemId  String // Specific item being returned
  reason       String // damaged, wrong-item, not-as-described, expired
  condition    String // new, used, damaged
  images       String? // JSON array of condition images
  description  String?
  refundType   String // refund, replacement, exchange
  refundAmount Float?
  status       String    @default("pending") // pending, approved, rejected, completed
  approvedBy   String? // Admin who approved
  approvedAt   DateTime?
  completedAt  DateTime?
  trackingId   String? // Return shipment tracking
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  // Relations
  order             Order              @relation(fields: [orderId], references: [id])
  RefundTransaction RefundTransaction?
  user User @relation(fields: [userId], references: [id])
}

// Refund Transaction model for refund processing
model RefundTransaction {
  id            String    @id @default(uuid())
  returnId      String    @unique
  paymentId     String? // Original payment ID for refund
  amount        Float
  status        String    @default("pending") // pending, processing, completed, failed
  gateway       String // razorpay, phonepe, bank
  gatewayId     String? // Refund ID from payment gateway
  processedAt   DateTime?
  failureReason String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  returnRequest ReturnRequest @relation(fields: [returnId], references: [id])
}

// Hero Slide model for homepage carousel
model HeroSlide {
  id        Int      @id @default(autoincrement())
  title     String
  subtitle  String?
  image     String
  link      String?
  order     Int
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Promotional Tile model for homepage 3-tile section
model PromotionalTile {
  id         Int      @id @default(autoincrement())
  title      String
  subtitle   String?
  category   String
  price      String
  image      String
  link       String
  badge      String?
  badgeColor String?
  order      Int
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Review model for product ratings
model Review {
  id          String   @id @default(uuid())
  productId   Int
  userId      String
  orderId     String? // Only verified purchases can review
  rating      Int // 1-5 stars
  title       String
  content     String
  images      String? // JSON array of review images
  isVerified  Boolean  @default(false) // Verified purchase
  isApproved  Boolean  @default(true) // Admin moderation
  helpful     Int      @default(0) // Helpful votes
  clinicalUse String? // Clinical use case (for dental professionals)
  efficacy    Int? // Efficacy rating (1-5)
  safety      Int? // Safety rating (1-5)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  product Product @relation(fields: [productId], references: [id])
  user    User    @relation(fields: [userId], references: [id])
  order   Order?  @relation(fields: [orderId], references: [id])

  @@unique([productId, userId]) // One review per user per product
}

// Indian Pincode model for serviceability
model IndianPincode {
  id            String  @id @default(uuid())
  pincode       String  @unique
  city          String
  state         String
  isServiceable Boolean @default(true)
  deliveryDays  Int     @default(3) // Standard delivery days
  codAvailable  Boolean @default(true)
  carriers      String? // JSON array of available carriers

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Shipping Tracking model
model ShippingTracking {
  id                String    @id @default(uuid())
  orderId           String    @unique
  carrier           String // delhivery, blue-dart, xpressbees, shiprocket
  trackingId        String    @unique
  serviceType       String // express, surface, economy
  status            String // in-transit, out-for-delivery, delivered
  estimatedDelivery DateTime?
  actualDelivery    DateTime?
  checkpoints       String? // JSON array of tracking checkpoints
  pincode           String // Indian pincode for delivery
  state             String // Indian state
  city              String // Indian city
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  order Order @relation(fields: [orderId], references: [id])
}

// Guest Session model for guest checkout tracking
model GuestSession {
  id        String   @id @default(uuid())
  email     String?
  phone     String?
  sessionId String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  
  // Relations
  orders Order[]
}

// Coupon model for discount management
model Coupon {
  id              String    @id @default(uuid())
  code            String    @unique
  type            String    // percentage, fixed, free_shipping
  value           Float
  minimumAmount   Float?
  maximumDiscount Float?
  usageLimit      Int?
  usageCount      Int       @default(0)
  userUsageLimit  Int?      // per user limit
  isActive        Boolean   @default(true)
  startsAt        DateTime
  expiresAt       DateTime
  applicableProducts String? // JSON array of product IDs
  applicableCategories String? // JSON array of category IDs
  userType        String?   // all, regular, dental-doctor
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  
  // Relations
  usedCoupons UsedCoupon[]
}

// Used Coupon model for tracking coupon usage
model UsedCoupon {
  id            String   @id @default(uuid())
  couponId      String
  userId        String?
  orderId       String
  discountAmount Float
  createdAt     DateTime @default(now())
  
  // Relations
  coupon Coupon @relation(fields: [couponId], references: [id])
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([orderId])
}

// Verification Document model for professional verification
model VerificationDocument {
  id           String    @id @default(uuid())
  userId       String
  documentType String    // license, certificate, id_proof, clinic_proof
  fileName     String
  fileUrl      String
  fileSize     Int
  mimeType     String
  status       String    @default("pending") // pending, approved, rejected
  reviewedBy   String?   // admin ID
  reviewedAt   DateTime?
  rejectionReason String?
  createdAt    DateTime  @default(now())
  
  // Relations
  user User @relation(fields: [userId], references: [id])
}

// Verification Audit model for verification workflow
model VerificationAudit {
  id          String    @id @default(uuid())
  userId      String
  action      String    // submitted, approved, rejected, resubmitted
  performedBy String    // admin ID or system
  notes       String?
  createdAt   DateTime  @default(now())
  
  // Relations
  user User @relation(fields: [userId], references: [id])
}

// WhatsApp Notification model
model WhatsAppNotification {
  id          String    @id @default(uuid())
  userId      String?
  phoneNumber String    // required for guest users
  orderId     String?
  messageType String    // order_confirmation, shipping_update, payment_reminder
  templateName String?  // WhatsApp template name
  content     String
  status      String    @default("pending") // pending, sent, delivered, failed
  messageId   String?   // WhatsApp message ID
  sentAt      DateTime?
  deliveredAt DateTime?
  failedReason String?
  retryCount  Int       @default(0)
  createdAt   DateTime  @default(now())
  
  // Relations

  order Order? @relation(fields: [orderId], references: [id])
  whatsappNotificationUser User? @relation(fields: [userId], references: [id])
}

// Saved Payment Method model
model SavedPaymentMethod {
  id          String  @id @default(uuid())
  userId      String
  type        String  // card, upi, netbanking
  token       String  // Payment gateway token
  last4       String? // Last 4 digits of card
  brand       String? // Visa, Mastercard, etc.
  expiry      String? // MM/YY
  isDefault   Boolean @default(false)
  gateway     String  // razorpay, phonepe
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  // Relations
  user User @relation(fields: [userId], references: [id])
}

// Quick Reorder model for one-click reorders
model QuickReorder {
  id                   String    @id @default(uuid())
  originalOrderId       String
  newOrderId           String
  userId               String
  status               String    @default("pending") // pending, completed, cancelled
  notes                String?
  quantityModifications  String?   // JSON string of quantity changes
  cancellationReason    String?
  createdAt            DateTime  @default(now())
  cancelledAt          DateTime?
  
  // Relations
  originalOrder Order @relation("QuickReorderOriginalOrder", fields: [originalOrderId], references: [id])
  newOrder     Order @relation("QuickReorderNewOrder", fields: [newOrderId], references: [id])
  user         User  @relation(fields: [userId], references: [id])
}
