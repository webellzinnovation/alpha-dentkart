# Backend Environment Variables

# Firebase Service Account (JSON content or file path)
# Option 1: Paste the entire JSON service account key here (for Vercel/production)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT_ID","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxxxx@YOUR_PROJECT_ID.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# Option 2: Or place firebase-service-account.json in backend/ directory (for local dev)
# The app will automatically detect and use it

# Server Configuration
PORT=3001
CLIENT_URL=http://localhost:3000
NODE_ENV=development

# JWT Secret (for authentication)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Database (Firebase Firestore - configured via service account above)

# Email Configuration (optional - emails logged if not configured)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your-email@gmail.com

# AI API Keys
GEMINI_API_KEY=your-gemini-api-key

# Razorpay (for payments)
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret

# WordPress Integration (optional)
WORDPRESS_URL=https://your-wordpress-site.com
WORDPRESS_USER=your-wp-username
WORDPRESS_APP_PASS=your-wp-app-password

# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,https://your-vercel-app.vercel.app
